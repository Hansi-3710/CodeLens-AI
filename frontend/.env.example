# Production only — leave unset for local dev (falls back to the Vite
# dev-server proxy defined in vite.config.ts, which forwards /api to
# http://localhost:8000).
#
# Set this in Vercel's project settings to your deployed backend's URL,
# e.g. https://llm-code-intel-api.onrender.com
VITE_API_BASE_URL=
